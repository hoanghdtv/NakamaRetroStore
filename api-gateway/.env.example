# Environment variables for the NestJS API Gateway
# Copy to .env and adjust for your environment

# Port the API Gateway listens on (default: 3000)
PORT=3000

# Internal URL of the Nakama container (use service name in Docker Compose)
NAKAMA_URL=http://nakama:7350

# Nakama server HTTP key (must match local.yml → runtime.http_key)
NAKAMA_HTTP_KEY=retro_server_http_key
