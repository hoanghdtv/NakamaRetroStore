{
  "files": [
    "src/users.ts",
    "src/achievements.ts",
    "src/games.ts",
    "src/roms.ts",
    "src/main.ts"
  ],
  "compilerOptions": {
    "target": "es5",
    "typeRoots": [
      "./node_modules"
    ],
    "outFile": "./build/index.js",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  }
}
